#!/bin/bash
#
# generate-index - Auto-generate INDEX.md files for fast agent orientation
#
# Usage:
#   generate-index [directory]           # Generate INDEX.md for directory
#   generate-index --all                 # Generate INDEX.md for all subdirectories
#   generate-index --type=root           # Force root-level index
#   generate-index --type=feature        # Force feature-level index
#   generate-index --type=sessions       # Force sessions-level index
#
# Detects directory type automatically:
# - Root: Contains PROJECT-STATE.md and multiple feature folders
# - Feature: Contains STATE.md and/or CLAUDE.md
# - Sessions: Contains session folders with dates (name_DD_MM_YYYY/)
#
# Part of ABDS (Agent Base Directory Specification) v1.0
# https://github.com/abds-spec/abds

set -euo pipefail

# Colors (respect NO_COLOR)
if [[ -z "${NO_COLOR:-}" ]]; then
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  BOLD='\033[1m'
  NC='\033[0m'
else
  GREEN=''; YELLOW=''; BLUE=''; BOLD=''; NC=''
fi

# Parse arguments
TARGET_DIR="${1:-.}"
INDEX_TYPE=""
GENERATE_ALL=false

if [[ "$TARGET_DIR" == "--all" ]]; then
  GENERATE_ALL=true
  TARGET_DIR="."
elif [[ "$TARGET_DIR" == --type=* ]]; then
  INDEX_TYPE="${TARGET_DIR#--type=}"
  TARGET_DIR="${2:-.}"
fi

# Make path absolute
TARGET_DIR=$(cd "$TARGET_DIR" && pwd)

echo ""
echo -e "${BOLD}Generating INDEX.md${NC}"
echo "===================="
echo "Directory: $TARGET_DIR"
echo ""

# Detect directory type if not specified
detect_type() {
  local dir="$1"

  # Check for root indicators
  if [[ -f "$dir/PROJECT-STATE.md" ]]; then
    echo "root"
    return
  fi

  # Check for feature indicators
  if [[ -f "$dir/STATE.md" || -f "$dir/CLAUDE.md" ]]; then
    echo "feature"
    return
  fi

  # Check for sessions indicators (contains folders with date pattern)
  local has_date_folders=false
  shopt -s nullglob
  for subdir in "$dir"/*/; do
    if [[ -d "$subdir" ]]; then
      local folder_name=$(basename "$subdir")
      # Check for _DD_MM_YYYY pattern
      if [[ "$folder_name" =~ _[0-9]{2}_[0-9]{2}_[0-9]{4}$ ]]; then
        has_date_folders=true
        break
      fi
    fi
  done
  shopt -u nullglob

  if $has_date_folders; then
    echo "sessions"
    return
  fi

  # Default to feature type
  echo "feature"
}

# Auto-detect type if not specified
if [[ -z "$INDEX_TYPE" ]]; then
  INDEX_TYPE=$(detect_type "$TARGET_DIR")
  echo -e "${BLUE}ℹ${NC}  Detected type: $INDEX_TYPE"
fi

# Count files and folders
count_files() {
  local dir="$1"
  find "$dir" -maxdepth 1 -type f -name "*.md" ! -name "INDEX.md" | wc -l | tr -d ' '
}

count_folders() {
  local dir="$1"
  find "$dir" -maxdepth 1 -type d ! -path "$dir" | wc -l | tr -d ' '
}

# Extract first line from markdown file (usually the title)
extract_title() {
  local file="$1"
  if [[ -f "$file" ]]; then
    head -1 "$file" | sed 's/^# //' | sed 's/^## //'
  else
    echo ""
  fi
}

# Extract status from STATE.md or CLAUDE.md
extract_status() {
  local dir="$1"
  if [[ -f "$dir/STATE.md" ]]; then
    # Look for status indicators
    if grep -q "✅" "$dir/STATE.md" 2>/dev/null; then
      echo "✅ Working"
    elif grep -q "🚧" "$dir/STATE.md" 2>/dev/null; then
      echo "🚧 In Progress"
    elif grep -q "⚠️" "$dir/STATE.md" 2>/dev/null; then
      echo "⚠️ Issues"
    else
      echo "📖 Documented"
    fi
  else
    echo "📁 Exists"
  fi
}

# Generate root-level INDEX.md
generate_root_index() {
  local dir="$1"
  local index_file="$dir/INDEX.md"

  echo -e "${BLUE}ℹ${NC}  Generating root-level INDEX.md..."

  local file_count=$(count_files "$dir")
  local folder_count=$(count_folders "$dir")

  cat > "$index_file" <<EOF
# $(basename "$dir") - Documentation Index

**Last Updated**: $(date +"%Y-%m-%d")
**Total Folders**: $folder_count
**Total Files**: $file_count

---

## Quick Navigation

- **[PROJECT-STATE.md](PROJECT-STATE.md)** - Current project overview ⭐ READ THIS FIRST
EOF

  # Add CLAUDE.md if exists
  if [[ -f "$dir/CLAUDE.md" ]]; then
    echo "- **[CLAUDE.md](CLAUDE.md)** - Project-level architecture" >> "$index_file"
  fi

  cat >> "$index_file" <<EOF
- **[Features](#features)** - All feature documentation
- **[Sessions](#sessions)** - Work history

---

## Features

EOF

  # List all subdirectories that look like features
  local feature_count=0
  for subdir in "$dir"/*/ ; do
    if [[ -d "$subdir" ]]; then
      local folder_name=$(basename "$subdir")

      # Skip certain folders
      if [[ "$folder_name" =~ ^(sessions|deprecated|IMPORTANT|plans)$ ]]; then
        continue
      fi

      local status=$(extract_status "$subdir")
      local file_count_sub=$(count_files "$subdir")
      local has_index=""

      if [[ -f "$subdir/INDEX.md" ]]; then
        has_index=" ([View Index]($folder_name/INDEX.md))"
      fi

      # Check if it has STATE.md
      local quick_links=""
      if [[ -f "$subdir/STATE.md" ]]; then
        quick_links=" | [State]($folder_name/STATE.md)"
      fi
      if [[ -f "$subdir/CLAUDE.md" ]]; then
        quick_links="$quick_links | [Architecture]($folder_name/CLAUDE.md)"
      fi
      if [[ -d "$subdir/sessions" ]]; then
        quick_links="$quick_links | [Sessions]($folder_name/sessions/)"
      fi

      cat >> "$index_file" <<EOF
### [$folder_name]($folder_name/INDEX.md)
**Status**: $status | **Files**: $file_count_sub$has_index
EOF

      if [[ -n "$quick_links" ]]; then
        echo "**Quick Links**:$quick_links" >> "$index_file"
      fi

      echo "" >> "$index_file"

      ((feature_count++))
    fi
  done

  # Add sessions section if exists
  if [[ -d "$dir/sessions" ]]; then
    cat >> "$index_file" <<EOF

---

## Sessions

### [sessions/](sessions/INDEX.md) - Work History
Chronological work history organized by topic.

EOF
  fi

  # Add IMPORTANT section if exists
  if [[ -d "$dir/IMPORTANT" ]]; then
    cat >> "$index_file" <<EOF

---

## Important

### [IMPORTANT/](IMPORTANT/INDEX.md) - Critical Patterns
Critical patterns, guidelines, and mistakes to avoid.

EOF
  fi

  # Add plans section if exists
  if [[ -d "$dir/plans" ]]; then
    local plan_count=$(count_files "$dir/plans")
    cat >> "$index_file" <<EOF

---

## Plans

### [plans/](plans/INDEX.md) - Implementation Plans
**Files**: $plan_count implementation plans

EOF
  fi

  # Footer
  cat >> "$index_file" <<EOF

---

## Statistics

**Total Features**: $feature_count
**Total Files**: $file_count
**Last Updated**: $(date +"%Y-%m-%d %H:%M")

---

**ABDS Compliant**: Level 2+ ⭐⭐
EOF

  echo -e "${GREEN}✓${NC} Generated root INDEX.md"
  echo "  Features: $feature_count"
  echo "  Files: $file_count"
}

# Generate feature-level INDEX.md
generate_feature_index() {
  local dir="$1"
  local index_file="$dir/INDEX.md"
  local feature_name=$(basename "$dir")

  echo -e "${BLUE}ℹ${NC}  Generating feature-level INDEX.md..."

  local file_count=$(count_files "$dir")
  local status=$(extract_status "$dir")

  cat > "$index_file" <<EOF
# $feature_name - Feature Index

**Last Updated**: $(date +"%Y-%m-%d")
**Total Files**: $file_count
**Status**: $status

---

## Quick Navigation

EOF

  # Add standard files if they exist
  if [[ -f "$dir/STATE.md" ]]; then
    echo "- [Current State](STATE.md) - What's working, known issues" >> "$index_file"
  fi
  if [[ -f "$dir/CLAUDE.md" ]]; then
    echo "- [Architecture](CLAUDE.md) - Design decisions and patterns" >> "$index_file"
  fi
  if [[ -d "$dir/sessions" ]]; then
    echo "- [Sessions Folder](sessions/) - Detailed work history" >> "$index_file"
  fi

  echo "" >> "$index_file"
  echo "---" >> "$index_file"
  echo "" >> "$index_file"
  echo "## Documentation Files" >> "$index_file"
  echo "" >> "$index_file"

  # List all markdown files (excluding INDEX.md, STATE.md, CLAUDE.md)
  local doc_count=0
  while IFS= read -r file; do
    if [[ -f "$file" ]]; then
      local filename=$(basename "$file")
      local filetitle=$(extract_title "$file")

      # Skip certain files
      if [[ "$filename" =~ ^(INDEX|STATE|CLAUDE)\.md$ ]]; then
        continue
      fi

      # Check if it's a raw transcript
      if [[ "$filename" == *"-raw.md" ]]; then
        continue  # We'll list these in a separate section
      fi

      if [[ -n "$filetitle" ]]; then
        echo "- **[$filename]($filename)** - $filetitle" >> "$index_file"
      else
        echo "- **[$filename]($filename)**" >> "$index_file"
      fi

      ((doc_count++))
    fi
  done < <(find "$dir" -maxdepth 1 -type f -name "*.md" ! -name "*-raw.md" | sort)

  # List raw transcripts if any
  local raw_count=0
  local raw_files=()
  while IFS= read -r file; do
    if [[ -f "$file" ]]; then
      raw_files+=("$file")
      ((raw_count++))
    fi
  done < <(find "$dir" -maxdepth 1 -type f -name "*-raw.md" | sort)

  if [[ $raw_count -gt 0 ]]; then
    cat >> "$index_file" <<EOF

---

## Raw Session Transcripts

These are detailed session transcripts with \`-raw.md\` suffix.

EOF

    for file in "${raw_files[@]}"; do
      local filename=$(basename "$file")
      echo "- **[$filename]($filename)**" >> "$index_file"
    done
  fi

  # Add sessions section if exists
  if [[ -d "$dir/sessions" ]]; then
    cat >> "$index_file" <<EOF

---

## Sessions

### [sessions/](sessions/INDEX.md) - Work History
Detailed work history for this feature.

EOF
  fi

  # Footer
  cat >> "$index_file" <<EOF

---

## File Organization

\`\`\`
$feature_name/
├── INDEX.md (this file)
EOF

  if [[ -f "$dir/STATE.md" ]]; then
    echo "├── STATE.md (current state)" >> "$index_file"
  fi
  if [[ -f "$dir/CLAUDE.md" ]]; then
    echo "├── CLAUDE.md (architecture)" >> "$index_file"
  fi
  if [[ $doc_count -gt 0 ]]; then
    echo "├── Documentation Files ($doc_count files)" >> "$index_file"
  fi
  if [[ $raw_count -gt 0 ]]; then
    echo "├── Raw Transcripts ($raw_count files)" >> "$index_file"
  fi
  if [[ -d "$dir/sessions" ]]; then
    echo "└── sessions/ (work history)" >> "$index_file"
  fi

  echo "\`\`\`" >> "$index_file"

  cat >> "$index_file" <<EOF

---

[← Back to Project](../INDEX.md)
EOF

  if [[ -d "$dir/sessions" ]]; then
    echo " | [View Sessions →](sessions/INDEX.md)" >> "$index_file"
  fi

  echo -e "${GREEN}✓${NC} Generated feature INDEX.md"
  echo "  Documentation: $doc_count files"
  echo "  Raw transcripts: $raw_count files"
}

# Generate sessions-level INDEX.md
generate_sessions_index() {
  local dir="$1"
  local index_file="$dir/INDEX.md"
  local parent_name=$(basename "$(dirname "$dir")")

  echo -e "${BLUE}ℹ${NC}  Generating sessions-level INDEX.md..."

  # Count session folders
  local session_count=0
  local sessions=()

  while IFS= read -r session_dir; do
    if [[ -d "$session_dir" ]]; then
      sessions+=("$session_dir")
      ((session_count++))
    fi
  done < <(find "$dir" -maxdepth 1 -type d ! -path "$dir" | sort -r)  # Reverse chronological

  cat > "$index_file" <<EOF
# $parent_name Sessions Index

Chronological work history for $parent_name feature.

**Total Sessions**: $session_count
**Last Updated**: $(date +"%Y-%m-%d")

---

## Recent Sessions (Last 10)

EOF

  # List recent sessions (up to 10)
  local count=0
  for session_dir in "${sessions[@]}"; do
    if [[ $count -ge 10 ]]; then
      break
    fi

    local session_name=$(basename "$session_dir")
    local session_file="$session_dir/$session_name.md"

    # Try to find the main session file
    if [[ ! -f "$session_file" ]]; then
      session_file=$(find "$session_dir" -maxdepth 1 -type f -name "*.md" ! -name "*-raw.md" | head -1)
    fi

    # Extract date from folder name
    local date_part=""
    if [[ "$session_name" =~ _([0-9]{2})_([0-9]{2})_([0-9]{4})$ ]]; then
      date_part="${BASH_REMATCH[3]}-${BASH_REMATCH[2]}-${BASH_REMATCH[1]}"
    fi

    # Extract description
    local desc_part=$(echo "$session_name" | sed 's/_[0-9]\{2\}_[0-9]\{2\}_[0-9]\{4\}$//' | tr '_' ' ' | sed 's/-/ /g')

    cat >> "$index_file" <<EOF
### $date_part: [$desc_part]($session_name/)
EOF

    # Try to extract summary from session file
    if [[ -f "$session_file" ]]; then
      local summary=$(grep -m 1 "^## " "$session_file" 2>/dev/null | sed 's/^## //' || echo "")
      if [[ -n "$summary" ]]; then
        echo "**Summary**: $summary" >> "$index_file"
      fi
    fi

    echo "" >> "$index_file"

    ((count++))
  done

  # List all sessions by date
  if [[ $session_count -gt 10 ]]; then
    cat >> "$index_file" <<EOF

---

## All Sessions ($session_count total)

EOF

    for session_dir in "${sessions[@]}"; do
      local session_name=$(basename "$session_dir")
      local date_part=""

      if [[ "$session_name" =~ _([0-9]{2})_([0-9]{2})_([0-9]{4})$ ]]; then
        date_part="${BASH_REMATCH[3]}-${BASH_REMATCH[2]}-${BASH_REMATCH[1]}"
      fi

      local desc_part=$(echo "$session_name" | sed 's/_[0-9]\{2\}_[0-9]\{2\}_[0-9]\{4\}$//' | tr '_' ' ' | sed 's/-/ /g')

      echo "- **$date_part**: [$desc_part]($session_name/)" >> "$index_file"
    done
  fi

  # Footer
  cat >> "$index_file" <<EOF

---

[← Back to Feature](../INDEX.md) | [↑ Project Index](../../INDEX.md)

---

**Total Sessions**: $session_count
**Generated**: $(date +"%Y-%m-%d %H:%M")
EOF

  echo -e "${GREEN}✓${NC} Generated sessions INDEX.md"
  echo "  Total sessions: $session_count"
}

# Generate based on type
case "$INDEX_TYPE" in
  root)
    generate_root_index "$TARGET_DIR"
    ;;
  feature)
    generate_feature_index "$TARGET_DIR"
    ;;
  sessions)
    generate_sessions_index "$TARGET_DIR"
    ;;
  *)
    echo -e "${YELLOW}⚠${NC}  Unknown type: $INDEX_TYPE"
    echo "Valid types: root, feature, sessions"
    exit 1
    ;;
esac

# Generate all subdirectories if --all flag
if $GENERATE_ALL; then
  echo ""
  echo -e "${BOLD}Generating INDEX.md for all subdirectories...${NC}"
  echo ""

  # Generate for each feature folder
  for subdir in "$TARGET_DIR"/*/ ; do
    if [[ -d "$subdir" ]]; then
      folder_name=$(basename "$subdir")

      # Skip certain folders
      if [[ "$folder_name" =~ ^(node_modules|\.git|dist|build)$ ]]; then
        continue
      fi

      echo "Processing: $folder_name"
      "$0" "$subdir"
    fi
  done
fi

echo ""
echo -e "${GREEN}✓ Done!${NC}"
echo ""
echo "INDEX.md generated at: $TARGET_DIR/INDEX.md"
echo ""
