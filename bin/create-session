#!/bin/bash
#
# create-session - Create a new ABDS session folder
#
# Usage: create-session [PROJECT_DIR]
#
# Creates a properly named session folder with template

set -euo pipefail

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default to current directory
PROJECT_DIR="${1:-.}"

if [[ ! -d "$PROJECT_DIR/.abds/docs" ]]; then
    echo "Error: Not an ABDS project (no .abds/docs/ directory found)"
    echo "Run 'init-abds' first to initialize ABDS in this project"
    exit 1
fi

ABDS_HOME="${ABDS_HOME:-$HOME/.abds}"
TEMPLATE_FILE="$ABDS_HOME/share/abds/templates/session-summary.md"

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Create New Session${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# List existing features
echo "Existing features:"
FEATURES=($(find "$PROJECT_DIR/.abds/docs" -mindepth 1 -maxdepth 1 -type d -not -name "IMPORTANT" -not -name "sessions" | xargs -n1 basename | sort))

if [[ ${#FEATURES[@]} -gt 0 ]]; then
    for i in "${!FEATURES[@]}"; do
        echo "  $((i+1)). ${FEATURES[$i]}"
    done
else
    echo "  (No features yet)"
fi

echo ""

# Prompt for feature
read -p "Select feature (1-${#FEATURES[@]}) or enter new name: " FEATURE_INPUT

if [[ "$FEATURE_INPUT" =~ ^[0-9]+$ ]] && [[ $FEATURE_INPUT -ge 1 ]] && [[ $FEATURE_INPUT -le ${#FEATURES[@]} ]]; then
    FEATURE="${FEATURES[$((FEATURE_INPUT-1))]}"
else
    FEATURE="$FEATURE_INPUT"
fi

echo ""
echo -e "Feature: ${GREEN}$FEATURE${NC}"

# Ensure feature directory exists
mkdir -p "$PROJECT_DIR/.abds/docs/$FEATURE/sessions"

# Prompt for description
echo ""
read -p "Session description (e.g., 'privacy-fix'): " DESCRIPTION

if [[ -z "$DESCRIPTION" ]]; then
    echo "Error: Description cannot be empty"
    exit 1
fi

# Generate session folder name
DATE=$(date +%d_%m_%Y)
SESSION_FOLDER="$PROJECT_DIR/.abds/docs/$FEATURE/sessions/${DESCRIPTION}_${DATE}"

# Create session folder
if [[ -d "$SESSION_FOLDER" ]]; then
    echo ""
    echo -e "${YELLOW}⚠️  Session folder already exists: $SESSION_FOLDER${NC}"
    read -p "Continue anyway? (y/N): " CONTINUE
    if [[ ! "$CONTINUE" =~ ^[Yy]$ ]]; then
        echo "Cancelled"
        exit 0
    fi
else
    mkdir -p "$SESSION_FOLDER"
fi

# Copy template if available
SESSION_FILE="$SESSION_FOLDER/${DESCRIPTION}.md"
if [[ -f "$TEMPLATE_FILE" ]]; then
    cp "$TEMPLATE_FILE" "$SESSION_FILE"
    # Replace placeholder in template
    sed -i.bak "s/\[Session Title\]/$DESCRIPTION/g" "$SESSION_FILE" 2>/dev/null || true
    sed -i.bak "s/YYYY-MM-DD/$(date +%Y-%m-%d)/g" "$SESSION_FILE" 2>/dev/null || true
    rm -f "$SESSION_FILE.bak"
else
    # Create basic template
    cat > "$SESSION_FILE" << EOF
# $DESCRIPTION

**Date**: $(date +%Y-%m-%d)
**Feature**: $FEATURE

## Summary

What was accomplished in this session.

## Problem

What problem was being solved?

## Solution

How was it solved?

## Files Changed

- \`path/to/file.ts\`

## Next Steps

- [ ] TODO item 1
- [ ] TODO item 2
EOF
fi

echo ""
echo -e "${GREEN}✓ Session created!${NC}"
echo ""
echo "  Folder: $SESSION_FOLDER"
echo "  File:   $SESSION_FILE"
echo ""

# Open in editor if EDITOR is set
if [[ -n "${EDITOR:-}" ]]; then
    read -p "Open in \$EDITOR ($EDITOR)? (Y/n): " OPEN_EDITOR
    if [[ ! "$OPEN_EDITOR" =~ ^[Nn]$ ]]; then
        $EDITOR "$SESSION_FILE"
    fi
fi
