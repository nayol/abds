#!/bin/bash
#
# validate-abds - Check ABDS compliance level
#
# Usage: validate-abds [project-path]
#
# Checks project for ABDS compliance and reports level:
# ⭐ Level 1 (Minimal): PROJECT-STATE.md + feature STATE.md
# ⭐⭐ Level 2 (Standard): + CLAUDE.md + sessions/
# ⭐⭐⭐ Level 3 (Full): + learnings + CATALOG.md + IMPORTANT/
#
# Exit codes:
#   0 = Level 3 (Full)
#   1 = Level 2 (Standard)
#   2 = Level 1 (Minimal)
#   3 = Not compliant
#
# Part of ABDS (Agent Base Directory Specification) v1.0
# https://github.com/abds-spec/abds

set -euo pipefail

# Colors (respect NO_COLOR)
if [[ -z "${NO_COLOR:-}" ]]; then
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  RED='\033[0;31m'
  BLUE='\033[0;34m'
  BOLD='\033[1m'
  NC='\033[0m'
else
  GREEN=''; YELLOW=''; RED=''; BLUE=''; BOLD=''; NC=''
fi

# Project directory (default: current directory)
PROJECT_DIR="${1:-.}"

# Make path absolute
PROJECT_DIR=$(cd "$PROJECT_DIR" && pwd)

echo ""
echo -e "${BOLD}ABDS Compliance Check${NC}"
echo "====================="
echo ""
echo "Checking: $PROJECT_DIR"
echo ""

# Support ABDS_HOME override
ABDS_HOME="${ABDS_HOME:-$HOME/.abds}"

# Check results
level1_pass=false
level2_pass=false
level3_pass=false

# Track findings
issues_level1=()
issues_level2=()
issues_level3=()

#
# Level 1: Minimal Compliance ⭐
#
echo -e "${BOLD}Level 1 (Minimal) ⭐${NC}"

# Check for .abds directory
if [[ -d "$PROJECT_DIR/.abds" ]]; then
  echo -e "  ${GREEN}✓${NC} .abds/ directory exists"
else
  echo -e "  ${RED}✗${NC} .abds/ directory not found"
  issues_level1+=("Create directory: mkdir -p .abds/docs")
fi

# Check for docs directory
if [[ -d "$PROJECT_DIR/.abds/docs" ]]; then
  echo -e "  ${GREEN}✓${NC} .abds/docs/ directory exists"
else
  echo -e "  ${RED}✗${NC} .abds/docs/ directory not found"
  issues_level1+=("Create directory: mkdir -p .abds/docs")
fi

# Check for PROJECT-STATE.md
if [[ -f "$PROJECT_DIR/.abds/docs/PROJECT-STATE.md" ]]; then
  echo -e "  ${GREEN}✓${NC} PROJECT-STATE.md found"
else
  echo -e "  ${RED}✗${NC} PROJECT-STATE.md not found"
  issues_level1+=("Create PROJECT-STATE.md from template")
fi

# Check for at least one feature with STATE.md
feature_count=0
if [[ -d "$PROJECT_DIR/.abds/docs" ]]; then
  for dir in "$PROJECT_DIR/.abds/docs"/*/ ; do
    if [[ -d "$dir" && "$dir" != *"/IMPORTANT/" ]]; then
      if [[ -f "$dir/STATE.md" ]]; then
        ((feature_count++))
      fi
    fi
  done
fi

if [[ $feature_count -gt 0 ]]; then
  echo -e "  ${GREEN}✓${NC} Feature STATE.md found ($feature_count features)"
else
  echo -e "  ${RED}✗${NC} No feature STATE.md found"
  issues_level1+=("Create at least one feature with STATE.md")
fi

# Determine if Level 1 passes
if [[ -d "$PROJECT_DIR/.abds/docs" && \
      -f "$PROJECT_DIR/.abds/docs/PROJECT-STATE.md" && \
      $feature_count -gt 0 ]]; then
  level1_pass=true
  echo ""
  echo -e "${GREEN}✓ Level 1 PASSED${NC}"
else
  echo ""
  echo -e "${RED}✗ Level 1 FAILED${NC}"
fi

echo ""

#
# Level 2: Standard Compliance ⭐⭐
#
echo -e "${BOLD}Level 2 (Standard) ⭐⭐${NC}"

if ! $level1_pass; then
  echo -e "  ${YELLOW}⊘${NC} Requires Level 1 first"
  echo ""
else
  # Check for CLAUDE.md in features
  claude_count=0
  if [[ -d "$PROJECT_DIR/.abds/docs" ]]; then
    for dir in "$PROJECT_DIR/.abds/docs"/*/ ; do
      if [[ -d "$dir" && "$dir" != *"/IMPORTANT/" ]]; then
        if [[ -f "$dir/CLAUDE.md" ]]; then
          ((claude_count++))
        fi
      fi
    done
  fi

  if [[ $claude_count -gt 0 ]]; then
    echo -e "  ${GREEN}✓${NC} Features have CLAUDE.md ($claude_count features)"
  else
    echo -e "  ${YELLOW}⚠${NC}  No CLAUDE.md found in features"
    issues_level2+=("Add CLAUDE.md to major features for architecture docs")
  fi

  # Check for sessions folders
  sessions_count=0
  if [[ -d "$PROJECT_DIR/.abds/docs" ]]; then
    for dir in "$PROJECT_DIR/.abds/docs"/*/ ; do
      if [[ -d "$dir" && "$dir" != *"/IMPORTANT/" ]]; then
        if [[ -d "$dir/sessions" ]]; then
          # Check if sessions has content
          session_folders=("$dir/sessions"/*/)
          if [[ ${#session_folders[@]} -gt 0 && -d "${session_folders[0]}" ]]; then
            ((sessions_count++))
          fi
        fi
      fi
    done
  fi

  if [[ $sessions_count -gt 0 ]]; then
    echo -e "  ${GREEN}✓${NC} Session folders exist ($sessions_count features)"
  else
    echo -e "  ${YELLOW}⚠${NC}  No session folders found"
    issues_level2+=("Create sessions/ folders for work history")
  fi

  # Check naming conventions (sample check)
  naming_ok=true
  if [[ -d "$PROJECT_DIR/.abds/docs" ]]; then
    for dir in "$PROJECT_DIR/.abds/docs"/*/ ; do
      if [[ -d "$dir/sessions" ]]; then
        for session in "$dir/sessions"/*/ ; do
          if [[ -d "$session" ]]; then
            session_name=$(basename "$session")
            # Check if matches {description}_{DD_MM_YYYY} pattern
            if ! [[ "$session_name" =~ ^[a-z0-9-]+_[0-9]{2}_[0-9]{2}_[0-9]{4}$ ]]; then
              naming_ok=false
              break 2
            fi
          fi
        done
      fi
    done
  fi

  if $naming_ok; then
    echo -e "  ${GREEN}✓${NC} Naming conventions followed"
  else
    echo -e "  ${YELLOW}⚠${NC}  Some naming conventions not followed"
    issues_level2+=("Follow naming: {description}_{DD_MM_YYYY}/")
  fi

  # Determine if Level 2 passes
  if [[ $claude_count -gt 0 && $sessions_count -gt 0 && $naming_ok == true ]]; then
    level2_pass=true
    echo ""
    echo -e "${GREEN}✓ Level 2 PASSED${NC}"
  else
    echo ""
    echo -e "${YELLOW}⚠ Level 2 PARTIAL${NC}"
  fi

  echo ""
fi

#
# Level 3: Full Compliance ⭐⭐⭐
#
echo -e "${BOLD}Level 3 (Full) ⭐⭐⭐${NC}"

if ! $level2_pass; then
  echo -e "  ${YELLOW}⊘${NC} Requires Level 2 first"
  echo ""
else
  # Check for ~/.abds/learnings/CATALOG.md
  if [[ -f "$ABDS_HOME/learnings/CATALOG.md" ]]; then
    echo -e "  ${GREEN}✓${NC} ~/.abds/learnings/CATALOG.md exists"
  else
    echo -e "  ${YELLOW}⚠${NC}  ~/.abds/learnings/CATALOG.md not found"
    issues_level3+=("Run: ~/.abds/bin/update-catalog")
  fi

  # Check for IMPORTANT/ directory
  if [[ -d "$PROJECT_DIR/.abds/docs/IMPORTANT" ]]; then
    echo -e "  ${GREEN}✓${NC} docs/IMPORTANT/ directory exists"
  else
    echo -e "  ${YELLOW}⚠${NC}  docs/IMPORTANT/ directory not found"
    issues_level3+=("Create: mkdir -p .abds/docs/IMPORTANT/{GUIDES,MISTAKES,LEARNINGS}")
  fi

  # Check for plans directory
  if [[ -d "$PROJECT_DIR/.abds/plans" || -d "$ABDS_HOME/plans" ]]; then
    echo -e "  ${GREEN}✓${NC} Plans directory exists"
  else
    echo -e "  ${YELLOW}⚠${NC}  Plans directory not found"
    issues_level3+=("Create: mkdir -p .abds/plans")
  fi

  # Check for bin/ scripts
  if [[ -d "$ABDS_HOME/bin" && -x "$ABDS_HOME/bin/update-catalog" ]]; then
    echo -e "  ${GREEN}✓${NC} Reference implementation scripts available"
  else
    echo -e "  ${BLUE}ℹ${NC}  Reference scripts not installed (optional)"
    issues_level3+=("Optional: Install scripts from https://github.com/abds-spec/abds")
  fi

  # Determine if Level 3 passes
  if [[ -f "$ABDS_HOME/learnings/CATALOG.md" && \
        -d "$PROJECT_DIR/.abds/docs/IMPORTANT" && \
        ( -d "$PROJECT_DIR/.abds/plans" || -d "$ABDS_HOME/plans" ) ]]; then
    level3_pass=true
    echo ""
    echo -e "${GREEN}✓ Level 3 PASSED${NC}"
  else
    echo ""
    echo -e "${YELLOW}⚠ Level 3 PARTIAL${NC}"
  fi

  echo ""
fi

#
# Summary
#
echo "━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if $level3_pass; then
  echo -e "${BOLD}${GREEN}Compliance Level: ⭐⭐⭐ (Full)${NC}"
  echo ""
  echo "Excellent! This project fully complies with ABDS."
  exit 0
elif $level2_pass; then
  echo -e "${BOLD}${GREEN}Compliance Level: ⭐⭐ (Standard)${NC}"
  echo ""
  echo "Good! This project meets standard compliance."
  echo ""
  if [[ ${#issues_level3[@]} -gt 0 ]]; then
    echo "For Level 3 (Full), complete:"
    for issue in "${issues_level3[@]}"; do
      echo "  • $issue"
    done
  fi
  exit 1
elif $level1_pass; then
  echo -e "${BOLD}${YELLOW}Compliance Level: ⭐ (Minimal)${NC}"
  echo ""
  echo "This project meets minimal compliance."
  echo ""
  if [[ ${#issues_level2[@]} -gt 0 ]]; then
    echo "For Level 2 (Standard), complete:"
    for issue in "${issues_level2[@]}"; do
      echo "  • $issue"
    done
  fi
  exit 2
else
  echo -e "${BOLD}${RED}Compliance Level: Not Compliant${NC}"
  echo ""
  echo "This project does not meet ABDS requirements."
  echo ""
  if [[ ${#issues_level1[@]} -gt 0 ]]; then
    echo "To achieve Level 1 (Minimal):"
    for issue in "${issues_level1[@]}"; do
      echo "  • $issue"
    done
    echo ""
    echo "Quick start:"
    echo "  cd $PROJECT_DIR"
    echo "  ~/.abds/bin/init-abds"
  fi
  exit 3
fi
