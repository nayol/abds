#!/usr/bin/env bash
#
# abds - Unified CLI for ABDS tools
#
# Part of ABDS (Agent Base Directory Specification) v1.0
# https://github.com/nayol/abds
#
# Usage: abds <command> [args...]
#
# This wrapper provides a unified interface to ABDS tools,
# similar to how 'git' wraps git-add, git-commit, etc.

set -euo pipefail

# Version
ABDS_VERSION="1.0.0"

# Directories
ABDS_HOME="${ABDS_HOME:-$HOME/.abds}"
ABDS_BIN="$ABDS_HOME/bin"

# Colors (respect NO_COLOR)
if [[ -z "${NO_COLOR:-}" ]] && [[ -t 1 ]]; then
  BOLD='\033[1m'
  DIM='\033[2m'
  GREEN='\033[0;32m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  BOLD=''; DIM=''; GREEN=''; BLUE=''; NC=''
fi

#
# show_help - Display help message
#
show_help() {
  cat <<EOF
${BOLD}abds${NC} - Agent Base Directory Specification CLI

${BOLD}USAGE${NC}
  abds [OPTIONS] [COMMAND] [ARGS...]

${BOLD}OPTIONS${NC}
  -h, --help       Show this help message
  -V, --version    Show ABDS version

${BOLD}COMMANDS${NC}
  ${GREEN}init${NC}, ${DIM}i${NC}          Initialize ABDS in current project
  ${GREEN}validate${NC}, ${DIM}v${NC}      Check ABDS compliance level
  ${GREEN}search${NC}, ${DIM}s${NC}        Search learnings by keywords
  ${GREEN}catalog${NC}          Update learnings catalog (CATALOG.md)
  ${GREEN}session${NC}          Create new session folder
  ${GREEN}find-files${NC}       Find documentation files needing better names
  ${GREEN}generate-index${NC}   Generate ABDS-INDEX.md for navigation

${BOLD}EXAMPLES${NC}
  ${DIM}# Initialize ABDS in project${NC}
  abds init

  ${DIM}# Search for learnings${NC}
  abds search "database RLS"
  abds s "oauth pkce"

  ${DIM}# Update catalog after adding learning${NC}
  abds catalog

  ${DIM}# Check compliance level${NC}
  abds validate
  abds v

  ${DIM}# Create session folder${NC}
  abds session "feature-implementation"

${BOLD}ENVIRONMENT VARIABLES${NC}
  ${BLUE}ABDS_HOME${NC}    Override default ~/.abds/ location
  ${BLUE}NO_COLOR${NC}     Disable colored output

${BOLD}DOCUMENTATION${NC}
  GitHub:  https://github.com/nayol/abds
  Spec:    $ABDS_HOME/share/abds/ABDS-1.0.md (if installed)

Run ${BOLD}abds <command> --help${NC} for command-specific help.
EOF
}

#
# show_version - Display version
#
show_version() {
  echo "ABDS ${ABDS_VERSION}"
}

#
# check_abds_installed - Verify ABDS is installed
#
check_abds_installed() {
  if [[ ! -d "$ABDS_HOME" ]]; then
    cat <<EOF >&2
${BOLD}Error:${NC} ABDS not found at $ABDS_HOME

${BOLD}Install ABDS:${NC}
  git clone https://github.com/nayol/abds.git
  cd abds
  ./bin/setup-global-abds.sh

Or set ABDS_HOME to point to your installation:
  export ABDS_HOME=/path/to/abds
EOF
    exit 1
  fi
}

#
# exec_tool - Execute ABDS tool
#
exec_tool() {
  local tool="$1"
  shift

  local tool_path="$ABDS_BIN/$tool"

  if [[ ! -x "$tool_path" ]]; then
    echo "${BOLD}Error:${NC} Tool '$tool' not found or not executable" >&2
    echo "" >&2
    echo "Expected: $tool_path" >&2
    echo "" >&2
    echo "This may indicate a corrupted ABDS installation." >&2
    echo "Try reinstalling: ./bin/setup-global-abds.sh" >&2
    exit 1
  fi

  # Execute tool (replaces this process, preserves exit code)
  exec "$tool_path" "$@"
}

#
# main - Command dispatcher
#
main() {
  # Handle no arguments
  if [[ $# -eq 0 ]]; then
    show_help
    exit 0
  fi

  # Handle options
  case "$1" in
    --help|-h)
      show_help
      exit 0
      ;;
    --version|-V)
      show_version
      exit 0
      ;;
  esac

  # Check ABDS is installed
  check_abds_installed

  # Dispatch to tools
  case "$1" in
    # init - Initialize ABDS in project
    init|i)
      shift
      exec_tool "init-abds" "$@"
      ;;

    # validate - Check compliance level
    validate|v)
      shift
      exec_tool "validate-abds" "$@"
      ;;

    # search - Search learnings
    search|s)
      shift
      exec_tool "search-learnings" "$@"
      ;;

    # catalog - Update learnings catalog
    catalog)
      shift
      exec_tool "update-catalog" "$@"
      ;;

    # session - Create session folder
    session)
      shift
      exec_tool "create-session" "$@"
      ;;

    # find-files - Find files needing better names
    find-files)
      shift
      exec_tool "find-files-to-rename" "$@"
      ;;

    # generate-index - Generate ABDS-INDEX.md
    generate-index)
      shift
      exec_tool "generate-index" "$@"
      ;;

    # Unknown command
    *)
      echo "${BOLD}Error:${NC} Unknown command '$1'" >&2
      echo "" >&2
      echo "Run ${BOLD}abds --help${NC} for available commands" >&2
      exit 1
      ;;
  esac
}

# Run main
main "$@"
